{
  "name": "work-schedule",
  "version": "0.1.0",
  "description": "BusyCal-like desktop calendar with lunar calendar and multi-slot reminders",
  "main": "./out/main/index.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && node scripts/dev-build.js && cross-env ELECTRON_RENDERER_URL=http://localhost:5173 electron .\"",
    "dev:renderer": "vite",
    "dev:electron": "electron-vite build && cross-env ELECTRON_RENDERER_URL=http:localhost:5173 electron .",
    "build": "node scripts/build.js",
    "build:renderer": "vite build",
    "build:main": "electron-vite build",
    "preview": "node scripts/build.js && electron .",
    "pack": "node scripts/pack.js",
    "pack:dir": "node scripts/pack-dir.js"
  },
  "build": {
    "appId": "com.work-schedule.app",
    "productName": "work-schedule",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "resources/**/*",
      "node_modules/better-sqlite3/**/*",
      "node_modules/dayjs/**/*",
      "node_modules/tyme4ts/**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "icon": "resources/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "work-schedule"
    }
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "dayjs": "^1.11.13",
    "tyme4ts": "^1.5.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^35.7.5",
    "electron-builder": "^25.1.0",
    "electron-vite": "^2.3.0",
    "pinia": "^2.2.0",
    "typescript": "^5.6.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.1.0",
    "wait-on": "^9.0.10"
  }
}
